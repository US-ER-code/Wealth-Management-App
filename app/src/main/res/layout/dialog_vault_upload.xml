<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent" android:layout_height="wrap_content"
    android:orientation="vertical" android:padding="20dp">
  <TextView android:text="Upload to Vault"
      android:textColor="@color/text_primary" android:textSize="18sp" android:fontFamily="sans-serif-medium"
      android:layout_width="wrap_content" android:layout_height="wrap_content"/>
  <TextView android:text="Store important documents securely with encryption"
      android:textColor="@color/text_secondary" android:textSize="13sp" android:layout_marginTop="4dp"
      android:layout_width="wrap_content" android:layout_height="wrap_content"/>
  <com.google.android.material.card.MaterialCardView style="@style/WGCard"
      android:layout_width="match_parent" android:layout_height="wrap_content"
      android:layout_marginTop="14dp">
    <LinearLayout android:id="@+id/btnUploadDevice" android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="horizontal" android:padding="14dp" android:gravity="center_vertical"
        android:clickable="true" android:focusable="true">
      <ImageView android:layout_width="32dp" android:layout_height="32dp"
          android:src="@drawable/ic_upload" app:tint="@color/teal_primary"
          android:background="@drawable/bg_icon_teal" android:padding="7dp"/>
      <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
          android:layout_weight="1" android:orientation="vertical" android:layout_marginStart="12dp">
        <TextView android:text="Upload from device" android:textColor="@color/text_primary"
            android:textSize="14sp" android:fontFamily="sans-serif-medium"
            android:layout_width="wrap_content" android:layout_height="wrap_content"/>
        <TextView android:text="PDF, JPG, PNG up to 10MB" android:textColor="@color/text_secondary" android:textSize="12sp"
            android:layout_width="wrap_content" android:layout_height="wrap_content"/>
      </LinearLayout>
    </LinearLayout>
  </com.google.android.material.card.MaterialCardView>
  <com.google.android.material.card.MaterialCardView style="@style/WGCard"
      android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="8dp">
    <LinearLayout android:id="@+id/btnImportDigilocker" android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="horizontal" android:padding="14dp" android:gravity="center_vertical"
        android:clickable="true" android:focusable="true">
      <ImageView android:layout_width="32dp" android:layout_height="32dp"
          android:src="@drawable/ic_document" app:tint="@color/teal_primary"
          android:background="@drawable/bg_icon_teal" android:padding="7dp"/>
      <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
          android:layout_weight="1" android:orientation="vertical" android:layout_marginStart="12dp">
        <TextView android:text="Import from DigiLocker" android:textColor="@color/text_primary"
            android:textSize="14sp" android:fontFamily="sans-serif-medium"
            android:layout_width="wrap_content" android:layout_height="wrap_content"/>
        <TextView android:text="Aadhaar, PAN, Policies and more" android:textColor="@color/text_secondary" android:textSize="12sp"
            android:layout_width="wrap_content" android:layout_height="wrap_content"/>
      </LinearLayout>
    </LinearLayout>
  </com.google.android.material.card.MaterialCardView>
  <Button android:id="@+id/btnClose" style="@style/WGButton.Text"
      android:layout_width="match_parent" android:layout_height="44dp"
      android:layout_marginTop="12dp" android:text="Close"/>
</LinearLayout>