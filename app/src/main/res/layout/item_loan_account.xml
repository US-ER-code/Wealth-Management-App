<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/cardRoot" style="@style/WGCard"
    android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginBottom="10dp">
  <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
      android:orientation="vertical" android:padding="14dp">
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="horizontal" android:gravity="center_vertical">
      <TextView android:id="@+id/tvInitials" android:layout_width="44dp" android:layout_height="44dp"
          android:gravity="center" android:text="HD" android:textColor="@color/warning_amber"
          android:textSize="14sp" android:fontFamily="sans-serif-medium" android:background="@drawable/bg_icon_orange"/>
      <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
          android:layout_weight="1" android:orientation="vertical" android:layout_marginStart="12dp">
        <TextView android:id="@+id/tvLoanName" android:text="HDFC Home Loan"
            android:textColor="@color/text_primary" android:textSize="15sp" android:fontFamily="sans-serif-medium"
            android:layout_width="wrap_content" android:layout_height="wrap_content"/>
        <TextView android:id="@+id/tvInstitution" android:text="HDFC Bank"
            android:textColor="@color/text_secondary" android:textSize="12sp"
            android:layout_width="wrap_content" android:layout_height="wrap_content"/>
      </LinearLayout>
      <TextView android:id="@+id/tvDueBadge" android:layout_width="wrap_content" android:layout_height="wrap_content"
          android:text="Due" android:textColor="@color/text_on_primary" android:textSize="11sp"
          android:background="@drawable/bg_badge_red" android:paddingHorizontal="8dp" android:paddingVertical="3dp"
          android:visibility="gone"/>
    </LinearLayout>
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="horizontal" android:layout_marginTop="10dp">
      <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
          android:layout_weight="1" android:orientation="vertical">
        <TextView android:text="Outstanding" android:textColor="@color/text_secondary" android:textSize="11sp"
            android:layout_width="wrap_content" android:layout_height="wrap_content"/>
        <TextView android:id="@+id/tvOutstanding" android:text="Rs.24.5L"
            android:textColor="@color/error_red" android:textSize="16sp" android:fontFamily="sans-serif-medium"
            android:layout_width="wrap_content" android:layout_height="wrap_content"/>
      </LinearLayout>
      <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
          android:layout_weight="1" android:orientation="vertical">
        <TextView android:id="@+id/tvEmi" android:text="EMI: Rs.32,500"
            android:textColor="@color/text_primary" android:textSize="13sp" android:fontFamily="sans-serif-medium"
            android:layout_width="wrap_content" android:layout_height="wrap_content"/>
        <TextView android:id="@+id/tvDueDate" android:text="Due: Thu, Nov 14"
            android:textColor="@color/text_secondary" android:textSize="12sp"
            android:layout_width="wrap_content" android:layout_height="wrap_content"/>
        <TextView android:id="@+id/tvTenure" android:text="180 months"
            android:textColor="@color/text_secondary" android:textSize="11sp"
            android:layout_width="wrap_content" android:layout_height="wrap_content"/>
      </LinearLayout>
    </LinearLayout>
  </LinearLayout>
</com.google.android.material.card.MaterialCardView>