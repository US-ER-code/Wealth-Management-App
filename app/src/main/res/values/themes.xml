<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">
    <style name="Theme.WealthGuardian" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorPrimary">@color/teal_primary</item>
        <item name="colorPrimaryVariant">@color/teal_primary_dark</item>
        <item name="colorOnPrimary">@color/text_on_primary</item>
        <item name="colorSecondary">@color/teal_accent</item>
        <item name="android:colorBackground">@color/bg_primary</item>
        <item name="colorSurface">@color/bg_card</item>
        <item name="colorOnSurface">@color/text_primary</item>
        <item name="android:statusBarColor">@color/bg_primary</item>
        <item name="android:windowLightStatusBar" tools:targetApi="m">true</item>
        <item name="materialAlertDialogTheme">@style/Theme.WealthGuardian.Dialog</item>
    </style>
    <style name="Theme.WealthGuardian.Splash" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="android:statusBarColor">@color/teal_primary</item>
        <item name="android:colorBackground">@color/teal_primary</item>
    </style>
    <style name="Theme.WealthGuardian.Dialog" parent="ThemeOverlay.MaterialComponents.MaterialAlertDialog">
        <item name="colorPrimary">@color/teal_primary</item>
        <item name="android:colorBackground">@color/bg_card</item>
    </style>
    <style name="WGCard" parent="Widget.MaterialComponents.CardView">
        <item name="cardBackgroundColor">@color/bg_card</item>
        <item name="cardCornerRadius">16dp</item>
        <item name="cardElevation">0dp</item>
        <item name="strokeWidth">1dp</item>
        <item name="strokeColor">@color/card_stroke</item>
    </style>
    <style name="WGButton.Primary" parent="Widget.MaterialComponents.Button">
        <item name="backgroundTint">@color/teal_primary</item>
        <item name="cornerRadius">12dp</item>
        <item name="android:textColor">@color/text_on_primary</item>
    </style>
    <style name="WGButton.Outlined" parent="Widget.MaterialComponents.Button.OutlinedButton">
        <item name="strokeColor">@color/teal_primary</item>
        <item name="android:textColor">@color/teal_primary</item>
        <item name="cornerRadius">12dp</item>
    </style>
    <style name="WGButton.Text" parent="Widget.MaterialComponents.Button.TextButton">
        <item name="android:textColor">@color/teal_primary</item>
    </style>
    <style name="WGTabLayout" parent="Widget.MaterialComponents.TabLayout">
        <item name="tabSelectedTextColor">@color/teal_primary</item>
        <item name="tabTextColor">@color/text_secondary</item>
        <item name="tabIndicatorColor">@color/teal_primary</item>
        <item name="tabIndicatorHeight">3dp</item>
        <item name="tabBackground">@android:color/transparent</item>
    </style>
    <style name="WGFab" parent="Widget.MaterialComponents.FloatingActionButton">
        <item name="backgroundTint">@color/teal_primary</item>
        <item name="tint">@color/text_on_primary</item>
    </style>
    <style name="WGChip" parent="Widget.MaterialComponents.Chip.Filter">
        <item name="chipBackgroundColor">@color/teal_primary_light</item>
        <item name="chipStrokeColor">@color/teal_primary</item>
        <item name="chipStrokeWidth">1dp</item>
        <item name="android:textColor">@color/teal_primary</item>
    </style>
</resources>