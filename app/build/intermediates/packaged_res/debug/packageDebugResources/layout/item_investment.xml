<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    style="@style/WGCard" android:layout_width="match_parent" android:layout_height="wrap_content"
    android:layout_marginBottom="10dp">
  <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
      android:orientation="horizontal" android:padding="14dp" android:gravity="center_vertical">
    <TextView android:id="@+id/tvInitials" android:layout_width="44dp" android:layout_height="44dp"
        android:gravity="center" android:text="CA" android:textColor="@color/success_green"
        android:textSize="14sp" android:fontFamily="sans-serif-medium" android:background="@drawable/bg_icon_green"/>
    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
        android:layout_weight="1" android:orientation="vertical" android:layout_marginStart="12dp">
      <TextView android:id="@+id/tvName" android:text="CAMS Mutual Funds"
          android:textColor="@color/text_primary" android:textSize="15sp" android:fontFamily="sans-serif-medium"
          android:layout_width="wrap_content" android:layout_height="wrap_content"/>
      <TextView android:id="@+id/tvType" android:text="Mutual Fund"
          android:textColor="@color/text_secondary" android:textSize="12sp"
          android:layout_width="wrap_content" android:layout_height="wrap_content"/>
      <TextView android:id="@+id/tvInvested" android:text="Invested: Rs.8L"
          android:textColor="@color/text_secondary" android:textSize="11sp"
          android:layout_width="wrap_content" android:layout_height="wrap_content"/>
    </LinearLayout>
    <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:orientation="vertical" android:gravity="end">
      <TextView android:id="@+id/tvCurrentValue" android:text="Rs.9.8L"
          android:textColor="@color/text_primary" android:textSize="16sp" android:fontFamily="sans-serif-medium"
          android:layout_width="wrap_content" android:layout_height="wrap_content"/>
      <TextView android:id="@+id/tvReturns" android:text="+Rs.1.8L (22%)"
          android:textColor="@color/success_green" android:textSize="12sp"
          android:layout_width="wrap_content" android:layout_height="wrap_content"/>
    </LinearLayout>
  </LinearLayout>
</com.google.android.material.card.MaterialCardView>