<?xml version="1.0" encoding="utf-8"?>
<androidx.swiperefreshlayout.widget.SwipeRefreshLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/swipeRefresh" android:layout_width="match_parent" android:layout_height="match_parent">
  <ScrollView android:layout_width="match_parent" android:layout_height="match_parent" android:fillViewport="true">
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical">

      <!-- Shimmer placeholder -->
      <LinearLayout android:id="@+id/shimmerLayout" android:visibility="gone"
          android:layout_width="match_parent" android:layout_height="wrap_content"
          android:orientation="vertical" android:padding="16dp">
        <View android:layout_width="match_parent" android:layout_height="160dp"
            android:background="@drawable/bg_shimmer_card" android:layout_marginBottom="12dp"/>
        <View android:layout_width="match_parent" android:layout_height="80dp"
            android:background="@drawable/bg_shimmer_card" android:layout_marginBottom="12dp"/>
        <View android:layout_width="match_parent" android:layout_height="120dp"
            android:background="@drawable/bg_shimmer_card"/>
      </LinearLayout>

      <!-- Main content -->
      <LinearLayout android:id="@+id/contentLayout"
          android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical">

        <!-- Header -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:paddingHorizontal="16dp"
            android:paddingTop="20dp" android:paddingBottom="8dp">
          <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
              android:layout_weight="1" android:orientation="vertical">
            <TextView android:text="Welcome back" android:textColor="@color/text_secondary" android:textSize="13sp"
                android:layout_width="wrap_content" android:layout_height="wrap_content"/>
            <TextView android:text="Your financial guardian" android:textColor="@color/text_primary"
                android:textSize="18sp" android:fontFamily="sans-serif-medium"
                android:layout_width="wrap_content" android:layout_height="wrap_content"/>
          </LinearLayout>
          <ImageView android:layout_width="40dp" android:layout_height="40dp"
              android:src="@drawable/ic_notification" android:background="@drawable/bg_circle_light"
              android:padding="8dp" app:tint="@color/teal_primary"/>
        </LinearLayout>

        <!-- Net Worth Card -->
        <com.google.android.material.card.MaterialCardView android:id="@+id/cardNetWorth"
            style="@style/WGCard" android:layout_width="match_parent" android:layout_height="wrap_content"
            android:layout_marginHorizontal="16dp" android:layout_marginTop="8dp">
          <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
              android:orientation="vertical" android:padding="16dp">
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:gravity="center_vertical">
              <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                  android:layout_weight="1" android:orientation="vertical">
                <TextView android:text="Net Worth" android:textColor="@color/text_secondary" android:textSize="12sp"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                <TextView android:id="@+id/tvNetWorthValue" android:text="Rs.24.5L"
                    android:textColor="@color/text_primary" android:textSize="28sp" android:fontFamily="sans-serif-medium"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                <TextView android:id="@+id/tvTodayChange" android:text="+Rs.8,200 today"
                    android:textColor="@color/success_green" android:textSize="12sp"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"/>
              </LinearLayout>
              <com.github.mikephil.charting.charts.LineChart android:id="@+id/sparklineChart"
                  android:layout_width="100dp" android:layout_height="50dp"/>
            </LinearLayout>
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:layout_marginTop="12dp">
              <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                  android:layout_weight="1" android:orientation="vertical">
                <TextView android:text="Cash" android:textColor="@color/text_secondary" android:textSize="11sp"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                <TextView android:id="@+id/tvCashValue" android:text="Rs.3.2L"
                    android:textColor="@color/text_primary" android:textSize="13sp" android:fontFamily="sans-serif-medium"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"/>
              </LinearLayout>
              <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                  android:layout_weight="1" android:orientation="vertical">
                <TextView android:text="Investments" android:textColor="@color/text_secondary" android:textSize="11sp"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                <TextView android:id="@+id/tvInvestmentsValue" android:text="Rs.19.8L"
                    android:textColor="@color/text_primary" android:textSize="13sp" android:fontFamily="sans-serif-medium"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"/>
              </LinearLayout>
              <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                  android:layout_weight="1" android:orientation="vertical">
                <TextView android:text="Liabilities" android:textColor="@color/text_secondary" android:textSize="11sp"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                <TextView android:id="@+id/tvLiabilitiesValue" android:text="-Rs.2.5L"
                    android:textColor="@color/error_red" android:textSize="13sp" android:fontFamily="sans-serif-medium"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"/>
              </LinearLayout>
            </LinearLayout>
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginTop="12dp">
              <ImageView android:layout_width="14dp" android:layout_height="14dp"
                  android:src="@drawable/ic_sync" app:tint="@color/text_secondary"/>
              <TextView android:id="@+id/tvLastSynced" android:text="Synced 2h ago"
                  android:textColor="@color/text_secondary" android:textSize="11sp" android:layout_marginStart="4dp"
                  android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"/>
              <TextView android:text="Read-only via AA" android:textColor="@color/text_on_primary"
                  android:textSize="11sp" android:background="@drawable/bg_badge_teal"
                  android:paddingHorizontal="8dp" android:paddingVertical="3dp"
                  android:layout_width="wrap_content" android:layout_height="wrap_content"/>
            </LinearLayout>
          </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Timeline Header -->
        <TextView android:id="@+id/tvTimelineHeader" android:text="3 actions due this week"
            android:textColor="@color/text_primary" android:textSize="15sp" android:fontFamily="sans-serif-medium"
            android:paddingHorizontal="16dp" android:paddingTop="20dp" android:paddingBottom="8dp"
            android:layout_width="wrap_content" android:layout_height="wrap_content"/>
        <androidx.recyclerview.widget.RecyclerView android:id="@+id/rvTimeline"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:paddingHorizontal="12dp" android:clipToPadding="false" android:orientation="horizontal"/>

        <!-- Quick Actions -->
        <TextView android:text="Quick actions" android:textColor="@color/text_primary"
            android:textSize="15sp" android:fontFamily="sans-serif-medium"
            android:paddingHorizontal="16dp" android:paddingTop="20dp" android:paddingBottom="10dp"
            android:layout_width="wrap_content" android:layout_height="wrap_content"/>
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:paddingHorizontal="16dp" android:weightSum="3">
          <LinearLayout android:id="@+id/btnLinkAA" android:layout_width="0dp" android:layout_height="wrap_content"
              android:layout_weight="1" android:orientation="vertical" android:gravity="center"
              android:background="@drawable/bg_quick_action_primary" android:layout_marginEnd="6dp"
              android:padding="14dp" android:clickable="true" android:focusable="true">
            <ImageView android:layout_width="24dp" android:layout_height="24dp"
                android:src="@drawable/ic_link" app:tint="@color/text_on_primary"/>
            <TextView android:text="Link via AA" android:textColor="@color/text_on_primary"
                android:textSize="11sp" android:layout_marginTop="4dp" android:gravity="center"
                android:layout_width="wrap_content" android:layout_height="wrap_content"/>
          </LinearLayout>
          <LinearLayout android:id="@+id/btnAddFamily" android:layout_width="0dp" android:layout_height="wrap_content"
              android:layout_weight="1" android:orientation="vertical" android:gravity="center"
              android:background="@drawable/bg_quick_action" android:layout_marginHorizontal="3dp"
              android:padding="14dp" android:clickable="true" android:focusable="true">
            <ImageView android:layout_width="24dp" android:layout_height="24dp"
                android:src="@drawable/ic_family" app:tint="@color/teal_primary"/>
            <TextView android:text="Add Family" android:textColor="@color/teal_primary"
                android:textSize="11sp" android:layout_marginTop="4dp" android:gravity="center"
                android:layout_width="wrap_content" android:layout_height="wrap_content"/>
          </LinearLayout>
          <LinearLayout android:id="@+id/btnUploadVault" android:layout_width="0dp" android:layout_height="wrap_content"
              android:layout_weight="1" android:orientation="vertical" android:gravity="center"
              android:background="@drawable/bg_quick_action" android:layout_marginStart="6dp"
              android:padding="14dp" android:clickable="true" android:focusable="true">
            <ImageView android:layout_width="24dp" android:layout_height="24dp"
                android:src="@drawable/ic_vault" app:tint="@color/teal_primary"/>
            <TextView android:text="Vault" android:textColor="@color/teal_primary"
                android:textSize="11sp" android:layout_marginTop="4dp" android:gravity="center"
                android:layout_width="wrap_content" android:layout_height="wrap_content"/>
          </LinearLayout>
        </LinearLayout>

        <!-- Accounts Snapshot -->
        <TextView android:text="Accounts" android:textColor="@color/text_primary"
            android:textSize="15sp" android:fontFamily="sans-serif-medium"
            android:paddingHorizontal="16dp" android:paddingTop="20dp" android:paddingBottom="8dp"
            android:layout_width="wrap_content" android:layout_height="wrap_content"/>
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="vertical" android:paddingHorizontal="16dp">
          <com.google.android.material.card.MaterialCardView android:id="@+id/cardBank"
              style="@style/WGCard" android:layout_width="match_parent" android:layout_height="wrap_content"
              android:layout_marginBottom="8dp">
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:padding="14dp" android:gravity="center_vertical">
              <ImageView android:layout_width="36dp" android:layout_height="36dp"
                  android:src="@drawable/ic_bank" android:background="@drawable/bg_icon_teal"
                  android:padding="8dp" app:tint="@color/teal_primary"/>
              <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                  android:layout_weight="1" android:orientation="vertical" android:layout_marginStart="12dp">
                <TextView android:text="Bank Accounts" android:textColor="@color/text_primary"
                    android:textSize="14sp" android:fontFamily="sans-serif-medium"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                <TextView android:id="@+id/tvBankBalance" android:text="Rs.3.2L"
                    android:textColor="@color/teal_primary" android:textSize="15sp" android:fontFamily="sans-serif-medium"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                <TextView android:text="2 accounts linked" android:textColor="@color/text_secondary" android:textSize="12sp"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"/>
              </LinearLayout>
              <ImageView android:layout_width="20dp" android:layout_height="20dp"
                  android:src="@drawable/ic_chevron_right" app:tint="@color/text_secondary"/>
            </LinearLayout>
          </com.google.android.material.card.MaterialCardView>
          <com.google.android.material.card.MaterialCardView android:id="@+id/cardLoans"
              style="@style/WGCard" android:layout_width="match_parent" android:layout_height="wrap_content"
              android:layout_marginBottom="8dp">
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:padding="14dp" android:gravity="center_vertical">
              <ImageView android:layout_width="36dp" android:layout_height="36dp"
                  android:src="@drawable/ic_loan" android:background="@drawable/bg_icon_orange"
                  android:padding="8dp" app:tint="@color/warning_amber"/>
              <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                  android:layout_weight="1" android:orientation="vertical" android:layout_marginStart="12dp">
                <TextView android:text="Credit and Loans" android:textColor="@color/text_primary"
                    android:textSize="14sp" android:fontFamily="sans-serif-medium"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                <TextView android:id="@+id/tvLoanOutstanding" android:text="Rs.2.5L outstanding"
                    android:textColor="@color/error_red" android:textSize="15sp" android:fontFamily="sans-serif-medium"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                <TextView android:text="Payment due Thu" android:textColor="@color/text_secondary" android:textSize="12sp"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"/>
              </LinearLayout>
              <ImageView android:layout_width="20dp" android:layout_height="20dp"
                  android:src="@drawable/ic_chevron_right" app:tint="@color/text_secondary"/>
            </LinearLayout>
          </com.google.android.material.card.MaterialCardView>
          <com.google.android.material.card.MaterialCardView android:id="@+id/cardInvestments"
              style="@style/WGCard" android:layout_width="match_parent" android:layout_height="wrap_content"
              android:layout_marginBottom="8dp">
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:padding="14dp" android:gravity="center_vertical">
              <ImageView android:layout_width="36dp" android:layout_height="36dp"
                  android:src="@drawable/ic_investment" android:background="@drawable/bg_icon_green"
                  android:padding="8dp" app:tint="@color/success_green"/>
              <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                  android:layout_weight="1" android:orientation="vertical" android:layout_marginStart="12dp">
                <TextView android:text="Investments" android:textColor="@color/text_primary"
                    android:textSize="14sp" android:fontFamily="sans-serif-medium"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                <TextView android:id="@+id/tvInvestmentValue" android:text="Rs.19.8L"
                    android:textColor="@color/success_green" android:textSize="15sp" android:fontFamily="sans-serif-medium"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                <TextView android:text="+12% this year" android:textColor="@color/text_secondary" android:textSize="12sp"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"/>
              </LinearLayout>
              <ImageView android:layout_width="20dp" android:layout_height="20dp"
                  android:src="@drawable/ic_chevron_right" app:tint="@color/text_secondary"/>
            </LinearLayout>
          </com.google.android.material.card.MaterialCardView>
          <com.google.android.material.card.MaterialCardView android:id="@+id/cardInsurance"
              style="@style/WGCard" android:layout_width="match_parent" android:layout_height="wrap_content">
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:padding="14dp" android:gravity="center_vertical">
              <ImageView android:layout_width="36dp" android:layout_height="36dp"
                  android:src="@drawable/ic_insurance" android:background="@drawable/bg_icon_purple"
                  android:padding="8dp" app:tint="#7C3AED"/>
              <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                  android:layout_weight="1" android:orientation="vertical" android:layout_marginStart="12dp">
                <TextView android:text="Insurance" android:textColor="@color/text_primary"
                    android:textSize="14sp" android:fontFamily="sans-serif-medium"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                <TextView android:id="@+id/tvInsuranceCoverage" android:text="Rs.1.5Cr coverage"
                    android:textColor="#7C3AED" android:textSize="15sp" android:fontFamily="sans-serif-medium"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                <TextView android:text="3 active policies" android:textColor="@color/text_secondary" android:textSize="12sp"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"/>
              </LinearLayout>
              <ImageView android:layout_width="20dp" android:layout_height="20dp"
                  android:src="@drawable/ic_chevron_right" app:tint="@color/text_secondary"/>
            </LinearLayout>
          </com.google.android.material.card.MaterialCardView>
        </LinearLayout>

        <!-- Security Strip -->
        <com.google.android.material.card.MaterialCardView style="@style/WGCard"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:layout_marginHorizontal="16dp" android:layout_marginTop="16dp"
            app:cardBackgroundColor="@color/teal_primary_light">
          <TextView android:text="Encrypted  Read-only  You control sharing"
              android:textColor="@color/teal_primary_dark" android:textSize="12sp"
              android:gravity="center" android:padding="10dp"
              android:layout_width="match_parent" android:layout_height="wrap_content"/>
        </com.google.android.material.card.MaterialCardView>

        <!-- Insights -->
        <TextView android:text="Insights" android:textColor="@color/text_primary"
            android:textSize="15sp" android:fontFamily="sans-serif-medium"
            android:paddingHorizontal="16dp" android:paddingTop="20dp" android:paddingBottom="8dp"
            android:layout_width="wrap_content" android:layout_height="wrap_content"/>
        <androidx.recyclerview.widget.RecyclerView android:id="@+id/rvInsights"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:paddingHorizontal="16dp" android:nestedScrollingEnabled="false"/>

        <!-- Consent Strip -->
        <com.google.android.material.card.MaterialCardView android:id="@+id/cardConsent"
            style="@style/WGCard" android:layout_width="match_parent" android:layout_height="wrap_content"
            android:layout_marginHorizontal="16dp" android:layout_marginTop="16dp" android:layout_marginBottom="24dp">
          <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
              android:orientation="horizontal" android:padding="14dp" android:gravity="center_vertical">
            <ImageView android:layout_width="20dp" android:layout_height="20dp"
                android:src="@drawable/ic_consent" app:tint="@color/teal_primary"/>
            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:orientation="vertical" android:layout_marginStart="10dp">
              <TextView android:id="@+id/tvConsentCount" android:text="3 active consents"
                  android:textColor="@color/teal_primary" android:textSize="13sp" android:fontFamily="sans-serif-medium"
                  android:layout_width="wrap_content" android:layout_height="wrap_content"/>
              <TextView android:id="@+id/tvConsentNames" android:text="HDFC Bank, ICICI CC, CAMS MF"
                  android:textColor="@color/text_secondary" android:textSize="11sp"
                  android:layout_width="wrap_content" android:layout_height="wrap_content"/>
            </LinearLayout>
            <ImageView android:layout_width="20dp" android:layout_height="20dp"
                android:src="@drawable/ic_chevron_right" app:tint="@color/text_secondary"/>
          </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

      </LinearLayout>
    </LinearLayout>
  </ScrollView>
</androidx.swiperefreshlayout.widget.SwipeRefreshLayout>